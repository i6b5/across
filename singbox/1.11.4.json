{
  "log": {
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "address": "tls://1.1.1.1",
        "strategy": "ipv4_only",
        "detour": "direct"
      }
    ]
  },
  "inbounds": [
    {
      "type": "vless",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "name": "reality",
          "uuid": "",
          "flow": "xtls-rprx-vision"
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "www.microsoft.com",
        "reality": {
          "enabled": true,
          "handshake": {
            "server": "www.microsoft.com",
            "server_port": 443
          },
          "private_key": "",
          "short_id": [
            ""
          ]
        }
      },
      "multiplex": {
        "enabled": false,
        "padding": false,
        "brutal": {
          "enabled": false,
          "up_mbps": 1000,
          "down_mbps": 1000
        }
      }
    },
    {
      "type": "tuic",
      "listen": "::",
      "listen_port": 443,
      "users": [
        {
          "uuid": "",
          "password": ""
        }
      ],
      "congestion_control": "bbr",
      "tls": {
        "enabled": true,
        "alpn": [
          "h3"
        ],
        "server_name": "",
        "acme": {
          "domain": "",
          "email": "",
          "dns01_challenge": {
            "provider": "cloudflare",
            "api_token": ""
          }
        }
      }
    },
    {
      "type": "hysteria2",
      "listen": "::",
      "listen_port": 443,
      "up_mbps": 1000,
      "down_mbps": 1000,
      "users": [
        {
          "password": ""
        }
      ],
      "tls": {
        "enabled": true,
        "server_name": "",
        "acme": {
          "domain": "",
          "email": "",
          "dns01_challenge": {
            "provider": "cloudflare",
            "api_token": ""
          }
        }
      }
    }
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "action": "hijack-dns"
      }
    ],
    "final": "direct"
  }
}